{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./node_modules/@sablier/devkit/tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@cli": ["./cli"],
      "@cli/*": ["./cli/*"],
      "@src": ["./src"],
      "@src/*.js": ["./src/*.ts", "./src/*.tsx", "./src/*.mts", "./src/*.cts"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["cli/**/*.ts", "scripts/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
