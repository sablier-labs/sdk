{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./node_modules/@sablier/devkit/tsconfig/base.json",
  "compilerOptions": {
    "paths": {
      "@src/*": ["./src/*"],
      "@src/*.js": ["./src/*.ts"]
