{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../node_modules/@sablier/devkit/tsconfig/build.json",
  "compilerOptions": {
    "outDir": "../dist",
    "paths": {
      "@src": ["../src"],
      "@src/*.js": ["../src/*.ts", "../src/*.tsx", "../src/*.mts", "../src/*.cts"],
      "@src/*": ["../src/*"]
    },
    "rootDir": "../src"
  },
  "exclude": ["../deployments", "../node_modules", "../src/internal"],
  "include": ["../src/**/*.ts"]
}
