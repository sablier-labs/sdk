{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../node_modules/@sablier/devkit/tsconfig/build.json",
  "compilerOptions": {
    // tsc-alias doesn't work without a `baseUrl`
    "baseUrl": "..",
    "outDir": "../dist",
    "paths": {
      "@/src/*": ["src/*"],
      "@/src/*.js": ["src/*.ts"]
    },
    "rootDir": "../src"
  },
  // These are relative to the config file, not to `baseUrl`
  "exclude": ["../deployments", "../node_modules", "../src/internal"],
  "include": ["../src/**/*.ts"]
}
