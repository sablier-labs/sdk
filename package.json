{
  "name": "sablier",
  "description": "Contract addresses, chain data, and deployment information for the Sablier Protocol",
  "license": "GPL-3.0-or-later",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "types": "./dist/types/index.d.ts",
  "typings": "./dist/types/index.d.ts",
  "version": "2.0.1",
  "type": "module",
  "author": {
    "name": "Sablier Labs Ltd",
    "url": "https://sablier.com"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "viem": "^2.44.2"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30",
    "@solana/web3.js": "^1.98",
    "viem": "^2.39"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@effect/platform": "^0.94.1",
    "@effect/vitest": "^0.27.0",
    "@sablier/devkit": "^1.11.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.7",
    "@vitest/ui": "^4.0.17",
    "commander": "^14.0.2",
    "concurrently": "^9.2.1",
    "globby": "11",
    "husky": "^9.1.7",
    "knip": "^5.80.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.0.11",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17",
    "winston": "^3.19.0"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./abi/*": "./abi/*",
    "./csv/*": "./csv/*",
    "./evm": {
      "types": "./dist/types/evm/index.d.ts",
      "import": "./dist/esm/evm/index.js",
      "default": "./dist/cjs/evm/index.js"
    },
    "./evm/*": {
      "types": "./dist/types/evm/*/index.d.ts",
      "import": "./dist/esm/evm/*/index.js",
      "default": "./dist/cjs/evm/*/index.js"
    },
    "./solana": {
      "types": "./dist/types/solana/index.d.ts",
      "import": "./dist/esm/solana/index.js",
      "default": "./dist/cjs/solana/index.js"
    },
    "./solana/*": {
      "types": "./dist/types/solana/*/index.d.ts",
      "import": "./dist/esm/solana/*/index.js",
      "default": "./dist/cjs/solana/*/index.js"
    },
    "./solana/releases/*/idl": {
      "types": "./dist/types/solana/releases/*/idl.d.ts",
      "import": "./dist/esm/solana/releases/*/idl.js",
      "default": "./dist/cjs/solana/releases/*/idl.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "abi/**",
    "dist/**",
    "csv/**",
    "CHANGELOG.md",
    "DOCS.md"
  ],
  "keywords": [
    "airdrops",
    "blockchain",
    "ethereum",
    "evm",
    "sablier",
    "sablier-airdrops",
    "sablier-flow",
    "sablier-lockup",
    "sablier-protocol",
    "smart-contracts",
    "token-streaming",
    "token-vesting",
    "vesting",
    "web3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sablier-labs/sdk.git"
  },
  "scripts": {
    "build": "just build",
    "prepack": "bun install --frozen-lockfile && just build",
    "setup": "husky"
  }
}
