{
  "name": "sablier",
  "description": "Contract addresses, chain data, and deployment information for the Sablier Protocol",
  "license": "GPL-3.0-or-later",
  "main": "./_cjs/index.js",
  "module": "./_esm/index.js",
  "types": "./_types/index.d.ts",
  "typings": "./_types/index.d.ts",
  "version": "2.0.0-beta.24",
  "author": {
    "name": "Sablier Labs Ltd",
    "url": "https://sablier.com"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "viem": "^2.44.2"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.30",
    "@solana/web3.js": "^1.98",
    "viem": "^2.39"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@effect/platform": "^0.94.1",
    "@effect/vitest": "^0.27.0",
    "@sablier/devkit": "^1.10.2",
    "@types/bun": "^1.3.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.7",
    "@vitest/ui": "^3.2.4",
    "commander": "^14.0.2",
    "fs-extra": "^11.3.3",
    "globby": "11",
    "husky": "^9.1.7",
    "knip": "^5.80.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "ultracite": "^7.0.11",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "winston": "^3.19.0"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./_types/index.d.ts",
      "import": "./_esm/index.js",
      "default": "./_cjs/index.js"
    },
    "./abi/*": "./abi/*",
    "./abi/*/*": "./abi/*/*",
    "./abi/*/*/*": "./abi/*/*/*",
    "./csv/*": "./csv/*",
    "./csv/*/*": "./csv/*/*",
    "./csv/*/*/*": "./csv/*/*/*",
    "./csv/*/*/*/*": "./csv/*/*/*/*",
    "./evm": {
      "types": "./_types/evm/index.d.ts",
      "import": "./_esm/evm/index.js",
      "default": "./_cjs/evm/index.js"
    },
    "./evm/*": {
      "types": "./_types/evm/*/index.d.ts",
      "import": "./_esm/evm/*/index.js",
      "default": "./_cjs/evm/*/index.js"
    },
    "./solana": {
      "types": "./_types/solana/index.d.ts",
      "import": "./_esm/solana/index.js",
      "default": "./_cjs/solana/index.js"
    },
    "./solana/*": {
      "types": "./_types/solana/*/index.d.ts",
      "import": "./_esm/solana/*/index.js",
      "default": "./_cjs/solana/*/index.js"
    },
    "./solana/releases/*/idl": {
      "types": "./_types/solana/releases/*/idl.d.ts",
      "import": "./_esm/solana/releases/*/idl.js",
      "default": "./_cjs/solana/releases/*/idl.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "evm": [
        "./_types/evm/index.d.ts"
      ],
      "evm/*": [
        "./_types/evm/*/index.d.ts"
      ],
      "solana": [
        "./_types/solana/index.d.ts"
      ],
      "solana/*": [
        "./_types/solana/*/index.d.ts"
      ],
      "solana/releases/*/idl": [
        "./_types/solana/releases/*/idl.d.ts"
      ]
    }
  },
  "files": [
    "_cjs",
    "_esm",
    "_types",
    "abi",
    "csv"
  ],
  "keywords": [
    "airdrops",
    "blockchain",
    "deployments",
    "ethereum",
    "evm",
    "foundry",
    "hardhat",
    "sablier",
    "sablier-airdrops",
    "sablier-flow",
    "sablier-lockup",
    "smart-contracts",
    "solidity",
    "token-streaming",
    "token-vesting",
    "vesting",
    "web3"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sablier-labs/sdk.git"
  },
  "scripts": {
    "build": "just build",
    "prepack": "bun install --frozen-lockfile && just build",
    "setup": "husky"
  },
  "sideEffects": false
}
